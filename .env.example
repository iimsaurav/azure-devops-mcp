# Azure DevOps organization URL (required)
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization

# Default project name (optional - can be passed per tool call)
AZURE_DEVOPS_PROJECT=your-project

# ──────────────────────────────────────────────
# Authentication (choose ONE method)
# ──────────────────────────────────────────────

# Method 1: Personal Access Token (simplest)
# AZURE_DEVOPS_PAT=your-personal-access-token

# Method 2: Service Principal (Client Credentials)
# AZURE_CLIENT_ID=your-app-client-id
# AZURE_CLIENT_SECRET=your-app-client-secret
# AZURE_TENANT_ID=your-tenant-id

# Method 3: Managed Identity (for Azure-hosted environments)
# AZURE_USE_MANAGED_IDENTITY=true
# AZURE_CLIENT_ID=your-user-assigned-identity-client-id  # optional, for user-assigned MI

# Method 4: Device Code Flow (default - no config needed)
# Just run the server and follow the on-screen instructions.
# Optionally set AZURE_TENANT_ID for single-tenant:
# AZURE_TENANT_ID=your-tenant-id
